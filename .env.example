# Azure Content Understanding in Foundry Tools
# Recommended auth path: leave CONTENT_UNDERSTANDING_API_KEY empty and use `az login`.
# For richer Markdown (figure descriptions/chart analysis), set the analyzer id
# to a copied/custom analyzer configured with those options in Content Understanding.

# Optional endpoint overrides for Azure OpenAI / Speech if you don't want to use
# the defaults baked into config.py.
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_MODEL=
AZURE_SPEECH_ENDPOINT=
AZURE_SPEECH_TRANSCRIPTION_MODEL=
AZURE_SPEECH_TRANSCRIPTION_LOCALES=
VOICE_MALE=en-US-Ethan:MAI-Voice-2
VOICE_FEMALE=en-US-Harper:MAI-Voice-2

CONTENT_UNDERSTANDING_ENDPOINT=https://your-foundry-resource.services.ai.azure.com/
CONTENT_UNDERSTANDING_ANALYZER_ID=prebuilt-documentSearch
CONTENT_UNDERSTANDING_API_VERSION=2025-11-01
CONTENT_UNDERSTANDING_PROCESSING_LOCATION=
CONTENT_UNDERSTANDING_API_KEY=
CONTENT_UNDERSTANDING_POLL_INTERVAL_SECONDS=2
